# Estellebot — production env template for VPS deploy.
# Copy to `.env` on the VPS, fill values, then `docker compose -f compose.prod.yml up -d`.
# NEVER commit a populated copy of this file.

# --- Required ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=  # service-role key (NOT anon)

# --- Optional AI verify (pick at most one; precedence: GEMINI > DEEPSEEK > OLLAMA) ---
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
OLLAMA_HOST=

# --- Tuning (defaults shown — usually leave alone) ---
# WORKER_CONCURRENCY=3
# REAPER_INTERVAL_MS=30000
# REAPER_TIMEOUT_MS=180000
# GRACEFUL_SHUTDOWN_MS=120000
# LOG_LEVEL=info
# HIPAA_DEEP_SCAN_ENABLED=true
