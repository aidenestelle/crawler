# Estellebot — environment configuration
#
# Copy to .env and fill in the required values.

# --- Required ----------------------------------------------------------------
# Supabase project that owns the `hipaa_deep_scans` table.
SUPABASE_URL=your_supabase_project_url
# Service role key (bypasses RLS — worker uses it to update row status).
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# --- Optional: worker tuning -------------------------------------------------
# Max concurrent scans per process (Playwright contexts). Default: 3
WORKER_CONCURRENCY=3
# How often (ms) to run reaper + tick. Default: 30000
REAPER_INTERVAL_MS=30000
# How long (ms) a running row may sit before the reaper releases it. Default: 180000 (3 min)
REAPER_TIMEOUT_MS=180000
# Optional prefix prepended to the worker id for log readability (e.g. "staging").
WORKER_ID_PREFIX=

# --- Optional: feature flags -------------------------------------------------
# Kill-switch for the HIPAA handler. Set to "false" to boot an idle worker.
HIPAA_DEEP_SCAN_ENABLED=true
# Log level: debug | info | warn | error. Default: info
LOG_LEVEL=info

# --- Optional: AI verification (Epic 3) --------------------------------------
# Provider precedence: GEMINI_API_KEY > DEEPSEEK_API_KEY > OLLAMA_HOST > disabled.
# Leave all blank to disable the AI pass (deterministic scan still runs).
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
OLLAMA_HOST=
OLLAMA_MODEL=gemma3:4b
# Hard timeout (ms) for the AI classify() call. Default: 15000. Ollama floors at 30000.
AI_VERIFY_TIMEOUT_MS=15000
